{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: compile",
            "type": "shell",
            "command": "mvn",
            "args": [
                "compile"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$maven"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
